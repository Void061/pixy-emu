generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User ──────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  pixies    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ownedRooms      Room[]
  ownedFurniture  FurnitureItem[]  @relation("FurnitureOwner")
  placedFurniture FurnitureItem[]  @relation("FurniturePlacer")
  roomRights      RoomRights[]
  roomBans        RoomBan[]
  chatMessages    ChatMessage[]
  roomVotes       RoomVote[]

  @@map("users")
}

// ─── Furniture Catalog ─────────────────────────────────────────────

model FurnitureDefinition {
  id               String  @id // es. "chair", "bed_single"
  name             String
  category         String  @default("uncategorized")
  price            Int     @default(0)
  sizeW            Int     @map("size_w")
  sizeH            Int     @map("size_h")
  isWalkable       Boolean @default(false) @map("is_walkable")
  isSittable       Boolean @default(false) @map("is_sittable")
  isLayable        Boolean @default(false) @map("is_layable")
  isUsable         Boolean @default(false) @map("is_usable")
  rotations        String[] // ["ne","se","sw","nw"]
  states           Json     // [{ id, label }]
  interactionPoints Json   @map("interaction_points") // { ne: {...}, se: {...} }
  zHeight          Int     @default(0) @map("z_height")
  spriteFormat     String  @default("png") @map("sprite_format")

  items FurnitureItem[]

  @@map("furniture_definitions")
}

// ─── Furniture Item (inventory OR placed in a room) ────────────────

model FurnitureItem {
  id           String  @id @default(uuid())
  definitionId String  @map("definition_id")
  ownerId      String  @map("owner_id")

  // Location: null = in inventory, set = placed in room
  roomId         String?   @map("room_id")
  placedByUserId String?   @map("placed_by_user_id")
  positionX      Int?      @map("position_x")
  positionY      Int?      @map("position_y")
  rotation       String    @default("se")
  currentState   String    @default("default") @map("current_state")
  placedAt       DateTime? @map("placed_at")

  createdAt DateTime @default(now()) @map("created_at")

  definition FurnitureDefinition @relation(fields: [definitionId], references: [id])
  owner      User                @relation("FurnitureOwner", fields: [ownerId], references: [id])
  room       Room?               @relation(fields: [roomId], references: [id], onDelete: SetNull)
  placedBy   User?               @relation("FurniturePlacer", fields: [placedByUserId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([roomId])
  @@map("furniture_items")
}

// ─── Room ──────────────────────────────────────────────────────────

model Room {
  id          String @id @default(uuid())
  ownerId     String @map("owner_id")
  name        String
  description String @default("")
  maxUsers    Int    @default(25) @map("max_users")

  width         Int @default(6)
  height        Int @default(6)
  doorTileX     Int @default(0) @map("door_tile_x")
  doorTileY     Int @default(0) @map("door_tile_y")
  entranceTileX Int @default(0) @map("entrance_tile_x")
  entranceTileY Int @default(0) @map("entrance_tile_y")

  theme Json @default("{}")

  // Access control
  accessMode String @default("open") @map("access_mode") // "open" | "doorbell" | "password"
  password   String? // hashed, only set when accessMode = "password"

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner        User            @relation(fields: [ownerId], references: [id])
  rights       RoomRights[]
  bans         RoomBan[]
  furniture    FurnitureItem[]
  chatMessages ChatMessage[]
  votes        RoomVote[]

  @@index([ownerId])
  @@map("rooms")
}

// ─── Room Votes ────────────────────────────────────────────────────

model RoomVote {
  id     String @id @default(uuid())
  roomId String @map("room_id")
  userId String @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@map("room_votes")
}

// ─── Room Rights ───────────────────────────────────────────────────

model RoomRights {
  id        String   @id @default(uuid())
  roomId    String   @map("room_id")
  userId    String   @map("user_id")
  grantedAt DateTime @default(now()) @map("granted_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@map("room_rights")
}

// ─── Chat Messages ─────────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(uuid())
  roomId    String   @map("room_id")
  userId    String   @map("user_id")
  username  String
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId, createdAt])
  @@map("chat_messages")
}

// ─── Room Bans ─────────────────────────────────────────────────────

model RoomBan {
  id       String   @id @default(uuid())
  roomId   String   @map("room_id")
  userId   String   @map("user_id")
  bannedAt DateTime @default(now()) @map("banned_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@map("room_bans")
}
